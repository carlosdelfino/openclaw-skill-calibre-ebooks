BOOKS_API_URL=http://host.docker.internal:6180
#BOOKS_API_URL=http://192.168.1.100:6180

# Calibre OpenClaw Server Configuration

# Calibre Database
CALIBRE_DB_PATH=/absolute/path/to/calibre/library/metadata.db
CALIBRE_LIBRARY_PATH=/absolute/path/to/calibre/library

# Server Configuration
SERVER_PORT=6180
SERVER_HOST=127.0.0.1

# API Security
# Generate with: openssl rand -hex 32
API_KEY=replace-with-a-random-64-character-token
ALLOW_UNAUTHENTICATED=false
CORS_ALLOW_ORIGINS=http://127.0.0.1:6180,http://localhost:6180
CORS_ALLOW_CREDENTIALS=false
ALLOW_BOOK_CONTENT_DOWNLOADS=false
ENABLE_NETWORK_BINDINGS_ENDPOINT=false
ENABLE_NETWORK_BINDINGS_MONITOR=false
ALLOW_GET_AUTO_SYNC=false

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text-v2-moe:latest
ALLOW_REMOTE_OLLAMA=false

# Embeddings Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
SIMILARITY_THRESHOLD=0.3
RAG_IDLE_SLEEP_SECONDS=60

# Nightly embedding service schedule
# Empty RAG_STOP_AT_LOCAL disables the worker deadline.
RAG_STOP_AT_LOCAL=06:00
RAG_TIMER_ON_CALENDAR=*-*-* 01:00:00
RAG_RUNTIME_MAX_SEC=5h
RAG_SERVICE_CONTINUOUS=true
RAG_PREFETCH_RANDOM_BOOKS=false
RAG_RECONCILE_ON_START=false
RAG_ALLOW_MODEL_PULL=false
INSTALL_NIGHTLY_EMBEDDINGS=false

# Manual run-rag.sh schedule
# Leave empty to run continuously until Ctrl+C.
RAG_RUN_STOP_AT_LOCAL=
RAG_RUN_IDLE_SLEEP_SECONDS=60

# PostgreSQL Configuration
POSTGRESQL_DB_USER=calibre_openclaw
POSTGRESQL_DB_PASSWD=replace-with-a-strong-password
POSTGRESQL_DB_DATABASE=calibre_openclaw
POSTGRESQL_DB_HOST=localhost
POSTGRESQL_DB_PORT=5432

# Logging Configuration
LOG_DIR=/mnt/Backup_2/Biblioteca/calibre-openclaw-server/logs
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
LOG_COMPRESS=true
