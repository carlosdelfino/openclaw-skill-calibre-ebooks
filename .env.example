# Configurações do RAG MCP Server
# Copie este arquivo para .env na raiz do projeto ou ajuste conforme necessário

# Configurações do Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text-v2-moe
# Outras opções de modelo:
# nomic-embed-text-v2-moe  (para português/multilíngue)
# bge-m3                   (para grandes acervos heterogêneos)

# ATENÇÃO: Uma vez criada a base de embeddings, não é possível trocar o modelo
# Para usar um modelo diferente, apague o diretório ~/.rapport/genais/data_rag e recrie com o novo modelo

# Configurações do Conversor de Documentos
DATA_DIR=../openclaw-calibre-rag/data
CONVERTED_DIR=../openclaw-calibre-rag/converteds
CHUNK_SIZE=500
CHUNK_OVERLAP=50
SIMILARITY_THRESHOLD=0.3

# Configurações de Banco de Dados
SQLITE_DB_PATH=../data/documents.db
CHROMA_DB_PATH=../data/chroma_db

# Configurações de OCR
TESSERACT_LANG=eng
# Para outros idiomas: eng, spa, fra, por, etc.

# Paths para dependências externas (se necessário)
# TESSERACT_CMD=/usr/bin/tesseract
# POPPLER_PATH=/usr/bin
# DJVU_PATH=/usr/bin

# API Keys para serviços externos (opcional)
# OPENAI_API_KEY=sk-proj-SUA_CHAVE_AQUI
# OPENAI_MODEL=GPT-5.4-mini
# WHISPER_MODEL=large-v3
# WHISPER_DEVICE=auto
