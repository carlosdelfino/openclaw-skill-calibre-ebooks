BOOKS_API_URL=http://0.0.0.0:6180

# Calibre library fallback
# CALIBRE_METADATA_DB=/path/to/metadata.db

# Ollama embeddings
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text-v2-moe

# RAG storage
DATA_DIR=/tmp/openclaw-calibre-rag/data
CONVERTED_DIR=/tmp/openclaw-calibre-rag/converteds
CHROMA_DB_PATH=/tmp/openclaw-calibre-rag/data/chroma_db

# Chunking and search
CHUNK_SIZE=500
CHUNK_OVERLAP=50
SIMILARITY_THRESHOLD=0.3

# OCR
TESSERACT_LANG=por
