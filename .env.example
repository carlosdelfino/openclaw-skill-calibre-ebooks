BOOKS_API_URL=http://host.docker.internal:6180

# Calibre OpenClaw Server Configuration

# Calibre Database
CALIBRE_DB_PATH=/mnt/Backup_2/Biblioteca/metadata.db
CALIBRE_LIBRARY_PATH=/mnt/Backup_2/Biblioteca

# Server Configuration
SERVER_PORT=6180
SERVER_HOST=0.0.0.0

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text-v2-moe:latest

# Embeddings Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
SIMILARITY_THRESHOLD=0.3

# PostgreSQL Configuration
POSTGRESQL_DB_USER=generativa
POSTGRESQL_DB_PASSWD=your_password_here
POSTGRESQL_DB_DATABASE=rapport_biblioteca
POSTGRESQL_DB_HOST=localhost
POSTGRESQL_DB_PORT=5432

# Logging Configuration
LOG_DIR=/mnt/Backup_2/Biblioteca/logs
LOG_RETENTION_DAYS=30
LOG_COMPRESS=true
